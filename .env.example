APP_NAME=nw-api-gogin
APP_ENV=local
APP_PORT=8080
# Host port for the Postgres container. Override if 5432 is taken by
# another container (e.g. docker-compose's default `postgres` service).
DB_PORT=5433
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
DATABASE_NAME=northwind
DATABASE_SSL_MODE=disable
DATABASE_MAX_IDLE_CONNS=10
DATABASE_MAX_OPEN_CONNS=25
DATABASE_CONN_MAX_LIFETIME_MINUTES=5
DATABASE_CONN_MAX_IDLE_MINUTES=5
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_SCRAPE_PORT=9090
